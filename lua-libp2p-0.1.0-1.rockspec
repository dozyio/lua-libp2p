    ["lua_libp2p.kad_dht.records"] = "lua_libp2p/kad_dht/records.lua",
    ["lua_libp2p.kad_dht.reprovider"] = "lua_libp2p/kad_dht/reprovider.lua",
    ["lua_libp2p.kad_dht.values"] = "lua_libp2p/kad_dht/values.lua",
    ["lua_libp2p.host"] = "lua_libp2p/host/init.lua",
