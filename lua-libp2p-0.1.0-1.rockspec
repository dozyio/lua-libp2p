    ["lua_libp2p.relay_discovery"] = "lua_libp2p/relay_discovery/init.lua",
    ["lua_libp2p.resource_manager"] = "lua_libp2p/resource_manager/init.lua",
    ["lua_libp2p.util.tables"] = "lua_libp2p/util/tables.lua",
    ["lua_libp2p.transport_circuit_relay_v2.autorelay"] = "lua_libp2p/transport_circuit_relay_v2/autorelay.lua",
    ["lua_libp2p.transport_circuit_relay_v2.protocol"] = "lua_libp2p/transport_circuit_relay_v2/protocol.lua",
    ["lua_libp2p.transport_circuit_relay_v2.client"] = "lua_libp2p/transport_circuit_relay_v2/client.lua",
    ["lua_libp2p.protocol_ping.service"] = "lua_libp2p/protocol_ping/service.lua",
    ["lua_libp2p.protocol_perf.service"] = "lua_libp2p/protocol_perf/service.lua",
    ["lua_libp2p.protocol_identify.protocol"] = "lua_libp2p/protocol_identify/protocol.lua",
    ["lua_libp2p.protocol_identify.service"] = "lua_libp2p/protocol_identify/service.lua",
    ["lua_libp2p.multiformats"] = "lua_libp2p/multiformats/init.lua",
    ["lua_libp2p.multiformats.varint"] = "lua_libp2p/multiformats/varint.lua",
    ["lua_libp2p.multiformats.multihash"] = "lua_libp2p/multiformats/multihash.lua",
    ["lua_libp2p.multiformats.base58btc"] = "lua_libp2p/multiformats/base58btc.lua",
    ["lua_libp2p.multiformats.base32"] = "lua_libp2p/multiformats/base32.lua",
    ["lua_libp2p.multiformats.cid"] = "lua_libp2p/multiformats/cid.lua",
    ["lua_libp2p.transport_tcp.transport"] = "lua_libp2p/transport_tcp/transport.lua",
    ["lua_libp2p.transport_tcp.luv"] = "lua_libp2p/transport_tcp/luv.lua",
    ["lua_libp2p.transport_tcp.luv_native"] = "lua_libp2p/transport_tcp/luv_native.lua",
    ["lua_libp2p.port_mapping.upnp"] = "lua_libp2p/port_mapping/upnp/init.lua",
