package = "lua-libp2p"
version = "0.1.0-1"
source = {
  url = "git://github.com/dozyio/lua-libp2p",
}
description = {
  summary = "libp2p port for Lua",
  detailed = "Rockspec for lua-libp2p and its runtime dependencies.",
  homepage = "https://github.com/dozyio/lua-libp2p",
  license = "MIT",
}
dependencies = {
  "lua >= 5.4",
  "luasocket >= 3.0",
  "lua-protobuf >= 0.5",
  "luasodium >= 2.4",
  "luv >= 1.0",
  "luaossl >= 20250929",
  "cqueues >= 20200726.54",
  "luasql-sqlite3 >= 2.6",
}
build = {
  type = "builtin",
  modules = {
    ["lua_libp2p"] = "lua_libp2p/init.lua",
    ["lua_libp2p.address_manager"] = "lua_libp2p/address_manager/init.lua",
    ["lua_libp2p.autonat"] = "lua_libp2p/autonat/init.lua",
    ["lua_libp2p.autonat.client"] = "lua_libp2p/autonat/client.lua",
    ["lua_libp2p.autonat.server"] = "lua_libp2p/autonat/server.lua",
    ["lua_libp2p.bootstrap"] = "lua_libp2p/bootstrap/init.lua",
    ["lua_libp2p.connection_encrypter"] = "lua_libp2p/connection_encrypter/init.lua",
    ["lua_libp2p.connection_manager"] = "lua_libp2p/connection_manager/init.lua",
    ["lua_libp2p.datastore"] = "lua_libp2p/datastore/init.lua",
    ["lua_libp2p.datastore.memory"] = "lua_libp2p/datastore/memory/init.lua",
    ["lua_libp2p.datastore.sqlite"] = "lua_libp2p/datastore/sqlite/init.lua",
    ["lua_libp2p.error"] = "lua_libp2p/error/init.lua",
    ["lua_libp2p.discovery"] = "lua_libp2p/discovery/init.lua",
    ["lua_libp2p.peer_discovery_mdns"] = "lua_libp2p/peer_discovery_mdns/init.lua",
    ["lua_libp2p.peer_discovery_mdns.dns"] = "lua_libp2p/peer_discovery_mdns/dns.lua",
    ["lua_libp2p.peer_discovery_bootstrap"] = "lua_libp2p/peer_discovery_bootstrap/init.lua",
    ["lua_libp2p.port_mapping"] = "lua_libp2p/port_mapping/init.lua",
    ["lua_libp2p.port_mapping.nat_pmp.client"] = "lua_libp2p/port_mapping/nat_pmp/client.lua",
    ["lua_libp2p.port_mapping.nat_pmp.service"] = "lua_libp2p/port_mapping/nat_pmp/service.lua",
    ["lua_libp2p.port_mapping.pcp.client"] = "lua_libp2p/port_mapping/pcp/client.lua",
    ["lua_libp2p.port_mapping.pcp.service"] = "lua_libp2p/port_mapping/pcp/service.lua",
    ["lua_libp2p.dnsaddr"] = "lua_libp2p/dnsaddr/init.lua",
    ["lua_libp2p.kad_dht.kbucket"] = "lua_libp2p/kad_dht/kbucket/init.lua",
    ["lua_libp2p.kad_dht"] = "lua_libp2p/kad_dht/init.lua",
    ["lua_libp2p.kad_dht.bootstrap"] = "lua_libp2p/kad_dht/bootstrap.lua",
    ["lua_libp2p.kad_dht.maintenance"] = "lua_libp2p/kad_dht/maintenance.lua",
    ["lua_libp2p.kad_dht.provider_routing"] = "lua_libp2p/kad_dht/provider_routing.lua",
    ["lua_libp2p.kad_dht.protocol"] = "lua_libp2p/kad_dht/protocol.lua",
    ["lua_libp2p.kad_dht.query"] = "lua_libp2p/kad_dht/query.lua",
    ["lua_libp2p.kad_dht.random_walk"] = "lua_libp2p/kad_dht/random_walk.lua",
